    "tile_col": "tile",
    "cloud_col": "cloud_scene",
    "px_count_col": "px_count",
    "index_filter": [
      "NDVI",
      "NDMI",
      "NDWI",
      "GNDVI",
      "SAVI",
      "OSAVI",
      "MSAVI",
      "MNDWI",
